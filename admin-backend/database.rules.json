{
  "rules": {
    "devices": {
      ".read": "auth != null && (auth.token.admin === true || root.child('authorizedAdminsUids').child(auth.uid).exists())",
      "$device_id": {
        ".read": "auth != null && (auth.token.admin === true || root.child('authorizedAdminsUids').child(auth.uid).exists())",
        ".write": "auth != null && (root.child('authorizedAdminsUids').child(auth.uid).exists() || !data.exists() || data.child('info/deviceId').val() == auth.uid || data.child('deviceId').val() == auth.uid)"
      }
    },
    "deviceSecrets": {
      ".read": "false",
      "$device_id": {
        ".write": "auth != null && (!data.exists() || root.child('authorizedAdminsUids').child(auth.uid).exists())"
      }
    },
    "authorizedAdmins": {
      ".read": "auth != null && root.child('authorizedAdminsUids').child(auth.uid).exists()",
      ".write": "false"
    },
    "authorizedAdminsUids": {
      ".read": "auth != null && root.child('authorizedAdminsUids').child(auth.uid).exists()",
      ".write": "false"
    },
    "commandLog": {
      ".read": "auth != null && (auth.token.admin === true || root.child('authorizedAdminsUids').child(auth.uid).exists())",
      ".write": "false"
    }
  }
}
